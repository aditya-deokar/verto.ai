// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectType {
  PRESENTATION
  MOBILE_DESIGN
}

enum PresentationGenerationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AiProvider {
  GOOGLE
  OPENAI
  GROQ
}

enum TemplateCategory {
  BUSINESS
  STARTUP_PITCH
  EDUCATION
  MARKETING
  CREATIVE
  TECHNOLOGY
  PROJECT_MANAGEMENT
  PERSONAL_EVENTS
  DATA_RESEARCH
  TRAINING
  MINIMAL
}

enum TemplateDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model User {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId            String   @unique
  name               String
  email              String   @unique
  profileImage       String?
  subscription       Boolean? @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lemonSqueezyApiKey String?
  storeId            String?
  webhookSecret      String?

  // Relations
  Projects           Project[]                   @relation("OwnedProjects")
  PurchasedProjects  Project[]                   @relation("PurchasedProjects")
  MobileProjects     MobileProject[]             @relation("UserMobileProjects")
  GenerationRuns     PresentationGenerationRun[]
  Subscription       Subscription?
  TemplateFavorites  TemplateFavorite[]
  AiKeys             UserAiKey[]
  usageCount         Int                         @default(0)
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
  PAUSED
  UNPAID
  ON_TRIAL
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String             @unique @db.Uuid
  lemonSqueezyId String             @unique // Subscription ID from Lemon Squeezy
  customerId     String // Customer ID from Lemon Squeezy
  orderId        String? // Order ID from Lemon Squeezy
  variantId      String // Product variant ID
  status         SubscriptionStatus @default(ACTIVE)

  // Billing details
  renewsAt    DateTime?
  endsAt      DateTime?
  trialEndsAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lemonSqueezyId])
  @@index([customerId])
}

model Project {
  id          String      @id @default(cuid())
  title       String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  slides      Json?
  userId      String      @db.Uuid
  outlines    String[]
  isDeleted   Boolean     @default(false)
  isPublished Boolean     @default(false)
  publishedAt DateTime?
  isSellable  Boolean     @default(false)
  varientId   String?
  thumbnail   String?
  themeName   String      @default("light")
  projectType ProjectType @default(PRESENTATION)

  // Relations
  User       User   @relation("OwnedProjects", fields: [userId], references: [id])
  Purchasers User[] @relation("PurchasedProjects")
}

model MobileProject {
  id        String   @id @default(cuid())
  userId    String   @db.Uuid
  name      String
  theme     String?
  thumbnail String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  // Relations
  user   User          @relation("UserMobileProjects", fields: [userId], references: [id])
  frames MobileFrame[]

  @@index([userId])
  @@index([createdAt])
}

model MobileFrame {
  id          String   @id @default(cuid())
  title       String
  htmlContent String   @db.Text
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  project MobileProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model PresentationGenerationRun {
  id              String                       @id @default(cuid())
  userId          String                       @db.Uuid
  topic           String
  status          PresentationGenerationStatus @default(PENDING)
  currentStepId   String?
  currentStepName String?
  progress        Int                          @default(0)
  error           String?
  steps           Json?
  projectId       String?
  completedAt     DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────
// TEMPLATES SYSTEM
// ─────────────────────────────────────────────────

model PresentationTemplate {
  id             String             @id @default(cuid())
  name           String
  description    String             @db.Text
  category       TemplateCategory
  tags           String[]
  difficulty     TemplateDifficulty @default(BEGINNER)
  slideCount     Int

  // Content — uses exact same Slide[] JSON as Project.slides
  slides         Json
  themeName      String
  layoutSequence String[]
  outlines       String[]

  // Visual
  thumbnail      String?
  previewImages  String[]

  // Flags
  isPremium      Boolean  @default(false)
  isNew          Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  isPublished    Boolean  @default(true)
  aiEnhanceable  Boolean  @default(true)

  // Analytics
  usageCount     Int      @default(0)
  ratingSum      Float    @default(0)
  ratingCount    Int      @default(0)

  // Authorship
  authorId       String?  @db.Uuid
  authorName     String   @default("Verto AI")

  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  favorites      TemplateFavorite[]

  @@index([category])
  @@index([isPremium])
  @@index([isFeatured])
  @@index([usageCount])
  @@index([createdAt])
}

model TemplateFavorite {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid
  templateId String
  createdAt  DateTime @default(now())

  // Relations
  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  template PresentationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([userId])
}

model UserAiKey {
  id           String     @id @default(cuid())
  userId       String     @db.Uuid
  provider     AiProvider
  key          String     // Encrypted key string
  iv           String     // Initialization vector for AES
  tag          String     // Authentication tag for GCM
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}
